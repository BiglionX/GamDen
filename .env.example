# ============================================
# GamDen 项目环境变量模板
# 复制为 .env 并填入真实值
# 同时支持 NestJS 后端 (gamden-backend) 和老 Express 后端 (./backend)
# ============================================

# ---------- 通用 ----------
NODE_ENV=production
PORT=3000
API_PREFIX=api/v1
CORS_ORIGIN=*
FRONTEND_URL=http://localhost:3001
LOG_LEVEL=info

# ---------- PostgreSQL（NestJS 后端，gamden-postgres 容器） ----------
DB_HOST=gamden-postgres
DB_PORT=5432
DB_USERNAME=gamden
DB_PASSWORD=gamden_secret
DB_DATABASE=gamden
DB_SYNCHRONIZE=false
DB_LOGGING=false

# MySQL 兼容 key（老 Express 后端使用，新部署可忽略）
DB_USER=root
DB_NAME=gamden
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0

# ---------- Redis ----------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=please_change_in_production
REDIS_DB=0

# ---------- JWT ----------
# 新 NestJS 后端使用 access/refresh 双 token
JWT_ACCESS_SECRET=change-me-access-secret-please-rotate-in-production
JWT_ACCESS_TTL=2h
JWT_REFRESH_SECRET=change-me-refresh-secret-please-rotate-in-production
JWT_REFRESH_TTL=14d
# 老 Express 后端 key（兼容保留）
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# ---------- 领地配置 ----------
TERRITORY_COORD_MIN=-1000
TERRITORY_COORD_MAX=1000
TERRITORY_NEIGHBOR_RANGE=10

# ---------- 邀请码 ----------
INVITE_CODE_LENGTH=8
INVITE_REQUIRED=true
INVITE_CODE_EXPIRE_DAYS=30

# ---------- 金币 / 等级 ----------
GOLD_COIN_INITIAL=100
GOLD_COIN_MAX=99999
LEVEL_MAX=5
LEVEL_EXP_THRESHOLDS=0,100,300,600,1000

# ---------- 野兽潮 ----------
BEAST_EVENT_PROBABILITY=0.2
BEAST_EVENT_CHECK_INTERVAL=3600

# ---------- API 限流 ----------
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# ---------- 内容审核 ----------
CONTENT_AUDIT_AUTO_PASS_THRESHOLD=90
CONTENT_AUDIT_MANUAL_REVIEW_THRESHOLD=70

# ---------- 腾讯云内容安全 ----------
TENCENT_CLOUD_SECRET_ID=your_secret_id
TENCENT_CLOUD_SECRET_KEY=your_secret_key
TENCENT_CLOUD_REGION=ap-guangzhou

# ---------- 微信小程序 ----------
WECHAT_APPID=your_wechat_appid
WECHAT_APPSECRET=your_wechat_appsecret
WECHAT_USE_MOCK=true
WECHAT_API_BASE=https://api.weixin.qq.com
WECHAT_PLATFORM_APPID=
WECHAT_PLATFORM_SECRET=
WECHAT_TOKEN_TTL=7000
WECHAT_MAX_RETRIES=2
WECHAT_RETRY_DELAY_MS=1000
WECHAT_QR_PAGE=pages/land/land

# ---------- OpenIM 即时通讯 ----------
OPENIM_USE_MOCK=true
OPENIM_API_URL=http://openim-server:18080
OPENIM_WS_URL=ws://openim-server:10001
OPENIM_SECRET_KEY=your_openim_secret
OPENIM_CALLBACK_URL=http://your_domain:3000/api/v1/webhook/openim
OPENIM_ADMIN_USERID=admin
OPENIM_ADMIN_TOKEN=
OPENIM_TOKEN_TTL=604800
OPENIM_TOKEN_SECRET=change-me-im-secret

# ---------- 推送 (uni-push / 个推) ----------
# 是否使用 mock 推送（true=只写日志不真发；false=调用个推 REST API）
PUSH_USE_MOCK=true
UNIPUSH_APPID=
UNIPUSH_APPKEY=
UNIPUSH_MASTERSECRET=
UNIPUSH_API_BASE=https://api.getui.com
UNIPUSH_REST_BASE=https://restapi.getui.com
# 服务器配置
SERVER_PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
LOG_LEVEL=info

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=gamden
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# JWT配置
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 腾讯云内容安全配置
TENCENT_CLOUD_SECRET_ID=your_secret_id
TENCENT_CLOUD_SECRET_KEY=your_secret_key
TENCENT_CLOUD_REGION=ap-guangzhou

# 微信小程序配置
WECHAT_APPID=your_wechat_appid
WECHAT_APPSECRET=your_wechat_appsecret

# OpenIM配置
OPENIM_API_URL=http://localhost:18080
OPENIM_SECRET_KEY=your_openim_secret
OPENIM_CALLBACK_URL=http://your_domain:3000/webhook/openim

# 邀请码配置
INVITE_CODE_EXPIRE_DAYS=30
INVITE_CODE_LENGTH=6

# 领地配置
TERRITORY_COORD_MIN=-1000
TERRITORY_COORD_MAX=1000
TERRITORY_NEIGHBOR_RANGE=10

# 金币配置
GOLD_COIN_INITIAL=100
GOLD_COIN_MAX=99999

# 等级配置
LEVEL_MAX=5
LEVEL_EXP_THRESHOLDS=0,100,300,600,1000

# 野兽潮配置
BEAST_EVENT_PROBABILITY=0.2
BEAST_EVENT_CHECK_INTERVAL=3600

# API限流配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# 内容审核配置
CONTENT_AUDIT_AUTO_PASS_THRESHOLD=90
CONTENT_AUDIT_MANUAL_REVIEW_THRESHOLD=70
