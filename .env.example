# 服务器配置
SERVER_PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001
LOG_LEVEL=info

# 数据库配置
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=gamden
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password
REDIS_DB=0

# JWT配置
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# 腾讯云内容安全配置
TENCENT_CLOUD_SECRET_ID=your_secret_id
TENCENT_CLOUD_SECRET_KEY=your_secret_key
TENCENT_CLOUD_REGION=ap-guangzhou

# 微信小程序配置
WECHAT_APPID=your_wechat_appid
WECHAT_APPSECRET=your_wechat_appsecret

# OpenIM配置
OPENIM_API_URL=http://localhost:18080
OPENIM_SECRET_KEY=your_openim_secret
OPENIM_CALLBACK_URL=http://your_domain:3000/webhook/openim

# 邀请码配置
INVITE_CODE_EXPIRE_DAYS=30
INVITE_CODE_LENGTH=6

# 领地配置
TERRITORY_COORD_MIN=-1000
TERRITORY_COORD_MAX=1000
TERRITORY_NEIGHBOR_RANGE=10

# 金币配置
GOLD_COIN_INITIAL=100
GOLD_COIN_MAX=99999

# 等级配置
LEVEL_MAX=5
LEVEL_EXP_THRESHOLDS=0,100,300,600,1000

# 野兽潮配置
BEAST_EVENT_PROBABILITY=0.2
BEAST_EVENT_CHECK_INTERVAL=3600

# API限流配置
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# 内容审核配置
CONTENT_AUDIT_AUTO_PASS_THRESHOLD=90
CONTENT_AUDIT_MANUAL_REVIEW_THRESHOLD=70
