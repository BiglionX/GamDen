# ============================================
# GamDen Backend - 环境变量模板
# 复制为 .env 并填入真实值（.env 不入 git）
# ============================================

# 应用
NODE_ENV=development
PORT=3000
API_PREFIX=api
CORS_ORIGIN=*

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=gamden
DB_PASSWORD=gamden_secret
DB_DATABASE=gamden
DB_SYNCHRONIZE=true            # 生产环境必须设为 false
DB_LOGGING=false

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=2h
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_TTL=14d

# 领地坐标范围（注册时随机分配）
TERRITORY_COORD_MIN=-1000
TERRITORY_COORD_MAX=1000

# 邀请码
INVITE_CODE_LENGTH=8
INVITE_REQUIRED=true

# ============================================
# OpenIM 即时通讯
# ============================================
# 是否使用 mock 实现（开发环境 true，生产环境 false）
OPENIM_USE_MOCK=true

# OpenIM Server 地址（mock 模式可忽略）
OPENIM_API_URL=http://127.0.0.1:10002
OPENIM_WS_URL=ws://127.0.0.1:10001

# OpenIM 管理员（user_register / force_logout 时鉴权用）
OPENIM_ADMIN_USERID=admin
# 通过 admin_login API 获取：`POST /auth/admin_login { secret: "openim 配置的 secret" }`
OPENIM_ADMIN_TOKEN=

# IM Token 有效期（秒，默认 7 天）
OPENIM_TOKEN_TTL=604800

# mock token 签名密钥（OPENIM_USE_MOCK=true 时生效）
OPENIM_TOKEN_SECRET=change-me-im-secret

# ============================================
# 微信开放平台 / 小程序
# ============================================
# 是否使用 mock 模式（开发环境 true，生产环境 false）
WECHAT_USE_MOCK=true

# 微信 API 基础地址
WECHAT_API_BASE=https://api.weixin.qq.com

# 平台主体小程序 AppID（用于平台级操作）
WECHAT_PLATFORM_APPID=

# 平台主体小程序 AppSecret（敏感信息，仅在环境变量中配置，绝不入 git）
WECHAT_PLATFORM_SECRET=

# access_token 缓存有效期（秒，默认 7000，比微信 7200 留 200s 缓冲）
WECHAT_TOKEN_TTL=7000

# API 调用失败重试次数
WECHAT_MAX_RETRIES=2

# 重试基础延迟（毫秒，指数退避：delay * 2^attempt）
WECHAT_RETRY_DELAY_MS=1000

# 小程序码默认落地页路径
WECHAT_QR_PAGE=pages/land/land

# ============================================
# 推送（uni-push / 个推）
# ============================================
# 是否使用 mock 推送（开发环境 true，生产环境 false）
# - true：仅写日志，不实际调用推送平台
# - false：调用 unipush（个推）REST API，需正确配置下方 appId/appKey/masterSecret
PUSH_USE_MOCK=true

# 个推 AppID（uni-push 概览页获取）
UNIPUSH_APPID=

# 个推 AppKey（同上）
UNIPUSH_APPKEY=

# 个推 MasterSecret（同上，敏感信息，仅在环境变量中配置，绝不入 git）
UNIPUSH_MASTERSECRET=

# 个推 API 地址（一般无需修改）
# - apiBase   ：鉴权域名（GET /auth、POST /auth）
# - restBase  ：推送业务域名（POST /push/*）
UNIPUSH_API_BASE=https://api.getui.com
UNIPUSH_REST_BASE=https://restapi.getui.com
