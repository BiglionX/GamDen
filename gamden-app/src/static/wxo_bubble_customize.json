      },
      "admin": {
        "background": "linear-gradient(135deg, #9B8AC4, #7B6BA4)",
        "color": "#1E241F",
        "text": "管理"
      }
    },
    "onlineDot": {
      "color": "#5A8F6C",
      "border": "2rpx solid #1E241F"
    }
  },

  "header": {
    "_comment": "顶部头（兼容老字段，新字段请使用 navigationBar）",
    "background": "#1E241F",
    "borderBottom": "1rpx solid rgba(201, 168, 124, 0.3)",
    "backdropFilter": "blur(10rpx)"
  },

  "customMessageTypes": {
    "_comment": "GamDen 自定义 contentType（与 OpenIM 协议对齐）",
    "TEXT": 101,
    "IMAGE": 102,
    "VOICE": 103,
    "VIDEO": 104,
    "FILE": 105,
    "AT": 106,
    "REVOKE": 110,
    "EMOJI": 115,
    "GUARDIAN_NOTICE": 200,
    "WELCOME": 201
  },

  "_platform_notes": {
    "UniApp_Web": "JSON 是主配置；前端组件读取 skin.* 全局字段 + bubbles.* + inputBar.*",
    "iOS_Native": "PLIST 与 JSON 字段一一对应；通过 wxo_bubble_customize.plist 加载",
    "Android_Native": "OpenIM Android SDK 不直接支持 PLIST；可读 JSON 后动态注入 native 主题",
    "MiniProgram": "JSON 字段直接使用；样式 token 已在 im-theme.scss 同步"
  }
