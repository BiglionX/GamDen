      "color": "#1E241F",
      "fontWeight": 600,
      "borderRadius": "32rpx",
      "padding": "12rpx 28rpx",
      "shadow": "0 2rpx 8rpx rgba(201, 168, 124, 0.4)",
      "border": "none"
    },
    "emojiButton": {
      "background": "rgba(201, 168, 124, 0.1)",
      "borderColor": "rgba(201, 168, 124, 0.35)",
      "iconColor": "#C9A87C",
      "size": "56rpx"
    },
    "moreButton": {
      "background": "rgba(201, 168, 124, 0.1)",
      "borderColor": "rgba(201, 168, 124, 0.35)",
      "iconColor": "#C9A87C",
      "size": "56rpx"
    }
  },

  "memberPanel": {
    "_comment": "右侧成员面板（侧滑抽屉）",
    "width": "78%",
    "maxWidth": "600rpx",
    "background": "linear-gradient(180deg, #1E241F 0%, #161A15 100%)",
    "backgroundPattern": "radial-gradient(circle at 20% 20%, rgba(201, 168, 124, 0.06) 1rpx, transparent 1rpx), radial-gradient(circle at 80% 80%, rgba(201, 168, 124, 0.06) 1rpx, transparent 1rpx)",
    "backgroundSize": "48rpx 48rpx",
    "shadow": "-8rpx 0 32rpx rgba(0, 0, 0, 0.6)",
    "headerBackground": "#262D27",
    "headerTextColor": "#F5F0E6",
    "roleBadge": {
      "owner": {
        "background": "linear-gradient(135deg, #C9A87C, #A8895F)",
        "color": "#1E241F",
